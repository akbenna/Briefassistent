// popup.js v4 — Fixed PDF, screenshot input, betere Bricks scraping

// ── PDF.js worker via extensie URL ───────────────────────────
// KRITIEKE FIX: worker moet via chrome-extension:// URL geladen worden
if (typeof pdfjsLib !== 'undefined') {
  pdfjsLib.GlobalWorkerOptions.workerSrc = chrome.runtime.getURL('pdfjs/pdf.worker.min.js');
}

// ── State ─────────────────────────────────────────────────────
const state = {
  // Dossier
  rawSecties: {},
  patiëntNaamRauw: '',
  initialen: '',
  sectieAan: {},
  dossierBron: null, // 'bricks' | 'screenshot' | 'pdf'
  // Screenshot
  screenshotDataUrl: null,
  screenshotAnalysed: false,
  // Vraag
  vraagText: null,
  vraagFileName: null,
  // Instellingen
  selectedType: 'advocaat',
};

// ── Init ──────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', async () => {
  await checkBricks();
  await loadApiKeyStatus();
  setupScreenshotPaste();
});

// ── Bricks check ──────────────────────────────────────────────
async function checkBricks() {
  const badge = document.getElementById('statusBadge');
  try {
    const [tab] = await chrome.tabs.query({ active: true, currentWindow: true });
    if (!tab) { badge.textContent = '⬤ Geen tab'; badge.className = 'badge off'; return; }

    const isBricks = tab.url && (
      tab.url.includes('brickshuisarts') ||
      tab.url.includes('bricks-his') ||
      tab.url.includes('bricks.')
    );

    if (!isBricks) {
      badge.textContent = '⬤ Geen Bricks';
      badge.className = 'badge off';
      document.getElementById('notBricks').style.display = 'block';
      return;
    }

    // Ping content script
    chrome.tabs.sendMessage(tab.id, { action: 'ping' }, (resp) => {
      if (chrome.runtime.lastError) {
        // Content script nog niet geladen — inject het nu
        chrome.scripting.executeScript({
          target: { tabId: tab.id },
          files: ['content.js']
        }, () => {
          badge.textContent = '⬤ Bricks (herlaad)';
          badge.className = 'badge on';
        });
      } else if (resp?.ok) {
        badge.textContent = '⬤ Bricks verbonden';
        badge.className = 'badge on';
      }
    });
  } catch(e) {
    badge.textContent = '⬤ Fout';
    badge.className = 'badge off';
  }
}

// ── Tab wisselen ──────────────────────────────────────────────
function switchTab(tab) {
  ['bricks','screenshot','pdf-dossier'].forEach(t => {
    document.getElementById('tab-' + t).classList.toggle('active', t === tab);
    document.getElementById('pane-' + t).style.display = t === tab ? 'block' : 'none';
  });
}

// ── BRICKS SCRAPEN ────────────────────────────────────────────
async function scrapeDossier() {
  const btn = document.getElementById('scrapeBtn');
  const debugEl = document.getElementById('scrapeDebug');
  btn.disabled = true;
  btn.textContent = '⏳ Bezig...';
  debugEl.style.display = 'none';
  clearError();

  try {
    const [tab] = await chrome.tabs.query({ active: true, currentWindow: true });
    if (!tab) { showError('Geen actieve tab gevonden.'); btn.disabled=false; btn.textContent='↓ Ophalen uit Bricks'; return; }

    // Probeer eerst via message, dan via scripting.executeScript
    const tryMessage = () => new Promise((resolve) => {
      chrome.tabs.sendMessage(tab.id, { action: 'scrapeDossier' }, (resp) => {
        if (chrome.runtime.lastError) resolve(null);
        else resolve(resp);
      });
    });

    const tryInject = () => new Promise((resolve) => {
      chrome.scripting.executeScript({
        target: { tabId: tab.id },
        func: () => {
          // Inline scraper als content script niet beschikbaar is
          function extractText(el) {
            const clone = el.cloneNode(true);
            clone.querySelectorAll('button,input,svg,script,style,nav').forEach(e=>e.remove());
            return (clone.innerText||clone.textContent||'').replace(/\t+/g,' ').replace(/ {3,}/g,'  ').replace(/\n{4,}/g,'\n\n').trim();
          }
          const body = document.body;
          const tekst = extractText(body).substring(0, 12000);
          const h1 = document.querySelector('h1,h2');
          return {
            secties: { 'Dossier (volledig)': tekst },
            patiëntNaamRauw: h1 ? h1.textContent.trim() : '',
            url: window.location.href
          };
        }
      }, (results) => {
        if (chrome.runtime.lastError || !results?.[0]) resolve(null);
        else resolve(results[0].result);
      });
    });

    let resp = await tryMessage();

    if (!resp || Object.values(resp.secties||{}).join('').length < 30) {
      // Inject content script en probeer opnieuw
      await chrome.scripting.executeScript({ target: { tabId: tab.id }, files: ['content.js'] });
      await new Promise(r => setTimeout(r, 500));
      resp = await tryMessage();
    }

    if (!resp || Object.values(resp.secties||{}).join('').length < 30) {
      // Laatste fallback: inline scraper
      resp = await tryInject();
    }

    if (!resp || Object.values(resp.secties||{}).join('').length < 10) {
      debugEl.style.display = 'block';
      debugEl.textContent = 'Weinig tekst gevonden op: ' + (resp?.url||'onbekend') +
        '\n\nTip: Zorg dat het dossier volledig geladen is en klik door alle tabs (Journaal, Medicatie, VG, Lab) voordat u ophaalt.';
      showError('Weinig tekst gevonden. Zie tip hieronder.');
      btn.disabled=false; btn.textContent='↓ Ophalen uit Bricks'; return;
    }

    state.rawSecties = resp.secties || {};
    state.patiëntNaamRauw = resp.patiëntNaamRauw || '';
    state.initialen = berekenInitialen(state.patiëntNaamRauw);
    state.dossierBron = 'bricks';

    // Standaard: bekende medische secties aan
    const standaardAan = ['journaal','medicatie','voorgeschied','lab'];
    state.sectieAan = {};
    for (const s of Object.keys(state.rawSecties)) {
      state.sectieAan[s] = standaardAan.some(kw => s.toLowerCase().includes(kw)) ||
                           Object.keys(state.rawSecties).length <= 2;
    }

    // UI updaten
    document.getElementById('scrapeIdle').style.display = 'none';
    document.getElementById('scrapeDone').style.display = 'block';
    const totChars = Object.values(state.rawSecties).join('').length;
    document.getElementById('scrapeMeta').textContent =
      Object.keys(state.rawSecties).join(' · ') + '\n' + Math.round(totChars/1000) + 'k tekens';
    document.getElementById('clearScrapeBtn').style.display = 'block';
    btn.textContent = '↓ Opnieuw ophalen';

    bouwTransparantiePaneel();
    clearError();

  } catch(e) {
    showError('Fout bij ophalen: ' + e.message);
  } finally {
    btn.disabled = false;
  }
}

function clearDossier() {
  state.rawSecties = {}; state.patiëntNaamRauw = ''; state.initialen = ''; state.sectieAan = {};
  state.screenshotDataUrl = null; state.screenshotAnalysed = false;
  document.getElementById('scrapeIdle').style.display = 'block';
  document.getElementById('scrapeDone').style.display = 'none';
  document.getElementById('transparantiePaneel').style.display = 'none';
  document.getElementById('clearScrapeBtn').style.display = 'none';
  document.getElementById('scrapeBtn').textContent = '↓ Ophalen uit Bricks';
  document.getElementById('scrapeDebug').style.display = 'none';
  clearScreenshot();
}

// ── SCREENSHOT ────────────────────────────────────────────────
function setupScreenshotPaste() {
  const area = document.getElementById('screenshotArea');
  area.addEventListener('click', () => area.focus());
  area.setAttribute('tabindex', '0');

  document.addEventListener('paste', (e) => {
    // Alleen als screenshot tab actief is
    if (document.getElementById('pane-screenshot').style.display === 'none') return;

    const items = e.clipboardData?.items;
    if (!items) return;

    for (const item of items) {
      if (item.type.startsWith('image/')) {
        const blob = item.getAsFile();
        const reader = new FileReader();
        reader.onload = (ev) => {
          state.screenshotDataUrl = ev.target.result;
          state.screenshotAnalysed = false;

          // Toon preview
          const preview = document.getElementById('screenshotPreview');
          preview.innerHTML = `<img src="${ev.target.result}" style="max-width:100%;max-height:200px;border-radius:5px;margin-top:8px">`;

          document.getElementById('analyseScreenshotBtn').style.display = 'block';
          document.getElementById('clearScreenshotBtn').style.display = 'block';
          document.getElementById('screenshotStatus').textContent = '✓ Screenshot geplakt — klik Analyseer';
        };
        reader.readAsDataURL(blob);
        e.preventDefault();
        return;
      }
    }
  });
}

async function analyseScreenshot() {
  if (!state.screenshotDataUrl) return;

  const btn = document.getElementById('analyseScreenshotBtn');
  const status = document.getElementById('screenshotStatus');
  btn.disabled = true;
  btn.textContent = '⏳ Analyseren...';
  status.textContent = 'AI leest het scherm...';
  clearError();

  const { apiKey } = await new Promise(r => chrome.storage.local.get('apiKey', r));
  if (!apiKey) { showError('Stel eerst uw API sleutel in.'); btn.disabled=false; btn.textContent='🔍 Analyseer screenshot'; return; }

  try {
    // Stuur screenshot naar Claude Vision
    const base64 = state.screenshotDataUrl.split(',')[1];
    const mediaType = state.screenshotDataUrl.match(/data:([^;]+)/)?.[1] || 'image/png';

    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true',
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 3000,
        messages: [{
          role: 'user',
          content: [
            {
              type: 'image',
              source: { type: 'base64', media_type: mediaType, data: base64 }
            },
            {
              type: 'text',
              text: `Dit is een screenshot van een medisch dossier systeem (Bricks HIS).
Extraheer alle medische informatie die zichtbaar is en structureer het per sectie.
Gebruik deze secties waar van toepassing: Journaal, Medicatie, Voorgeschiedenis, Lab, Metingen, Allergieën, Correspondentie.
Schrijf alle tekst letterlijk over zoals zichtbaar, inclusief datums, ICPC-codes, medicatienamen en doseringen.
Laat GEEN informatie weg. Geef de output als platte tekst per sectie.`
            }
          ]
        }]
      })
    });

    if (!resp.ok) {
      const err = await resp.json().catch(()=>({}));
      throw new Error(err.error?.message || `API fout ${resp.status}`);
    }

    const data = await resp.json();
    const tekst = data.content.map(b => b.text||'').join('\n');

    // Parseer secties uit de AI output
    const secties = {};
    const sectieTitels = ['Journaal','Medicatie','Voorgeschiedenis','Lab','Metingen','Allergieën','Correspondentie','Problemen'];
    let huidigeSectie = 'Dossier';
    let huidigeTekst = '';

    tekst.split('\n').forEach(lijn => {
      const gevondenSectie = sectieTitels.find(s =>
        lijn.toLowerCase().includes(s.toLowerCase()) && lijn.length < 50
      );
      if (gevondenSectie) {
        if (huidigeTekst.trim()) secties[huidigeSectie] = huidigeTekst.trim();
        huidigeSectie = gevondenSectie;
        huidigeTekst = '';
      } else {
        huidigeTekst += lijn + '\n';
      }
    });
    if (huidigeTekst.trim()) secties[huidigeSectie] = huidigeTekst.trim();

    state.rawSecties = secties;
    state.patiëntNaamRauw = '';
    state.initialen = 'P.X.';
    state.dossierBron = 'screenshot';
    state.sectieAan = {};
    const standaardAan = ['journaal','medicatie','voorgeschied','lab'];
    for (const s of Object.keys(secties)) {
      state.sectieAan[s] = standaardAan.some(kw => s.toLowerCase().includes(kw)) || Object.keys(secties).length <= 2;
    }

    state.screenshotAnalysed = true;
    status.textContent = `✓ ${Object.keys(secties).length} secties herkend uit screenshot`;
    btn.textContent = '🔍 Opnieuw analyseren';

    bouwTransparantiePaneel();
    clearError();

  } catch(e) {
    showError('Screenshot analyse mislukt: ' + e.message);
    status.textContent = '';
  } finally {
    btn.disabled = false;
  }
}

function clearScreenshot() {
  state.screenshotDataUrl = null;
  state.screenshotAnalysed = false;
  document.getElementById('screenshotPreview').innerHTML = '';
  document.getElementById('analyseScreenshotBtn').style.display = 'none';
  document.getElementById('clearScreenshotBtn').style.display = 'none';
  document.getElementById('screenshotStatus').textContent = '';
}

// ── PDF DOSSIER ───────────────────────────────────────────────
function dzDropDossier(e) {
  e.preventDefault();
  document.getElementById('dropDossier').classList.remove('over');
  const f = e.dataTransfer.files[0];
  if (f?.type==='application/pdf') loadDossierPDF({target:{files:[f]}});
  else showError('Alleen PDF bestanden.');
}

async function loadDossierPDF(event) {
  const file = event.target.files[0];
  if (!file) return;
  document.getElementById('dropDossierLabel').innerHTML = '⏳ PDF lezen...';
  clearError();

  try {
    const tekst = await leesPDF(file);
    // Splits in ruwe secties op basis van keywords
    const secties = parseerPDFTekst(tekst);
    state.rawSecties = secties;
    state.patiëntNaamRauw = '';
    state.initialen = 'P.X.';
    state.dossierBron = 'pdf';
    state.sectieAan = {};
    const standaardAan = ['journaal','medicatie','voorgeschied','lab'];
    for (const s of Object.keys(secties)) {
      state.sectieAan[s] = standaardAan.some(kw => s.toLowerCase().includes(kw)) || Object.keys(secties).length <= 2;
    }
    document.getElementById('dropDossierLabel').innerHTML = `📄 ${file.name} (${Math.round(tekst.length/1000)}k tekens)`;
    document.getElementById('dropDossier').classList.add('loaded');
    document.getElementById('dossierPillText').textContent = `${Object.keys(secties).length} secties gelezen`;
    document.getElementById('dossierPill').style.display = 'flex';
    bouwTransparantiePaneel();
  } catch(e) {
    showError('PDF leesfout: ' + e.message);
    document.getElementById('dropDossierLabel').innerHTML = '📄 Sleep Medicom/Bricks PDF export hier';
  }
}

function clearDossierPDF() {
  state.rawSecties = {}; state.dossierBron = null;
  document.getElementById('dropDossierLabel').innerHTML = '📄 Sleep Medicom/Bricks PDF export hier<br><small>of klik om te bladeren</small>';
  document.getElementById('dropDossier').classList.remove('loaded');
  document.getElementById('dossierPill').style.display = 'none';
  document.getElementById('fileDossier').value = '';
  document.getElementById('transparantiePaneel').style.display = 'none';
}

function parseerPDFTekst(tekst) {
  const sectieMap = {
    'Journaal':['journaal','soep','consult','icpc'],
    'Medicatie':['medicatie','recept','geneesmiddel'],
    'Voorgeschiedenis':['voorgeschied','anamnese'],
    'Lab':['lab','bepaling','bloedwaarden','uitslag'],
    'Correspondentie':['correspon','verwijz','specialist'],
    'Metingen':['meting','bloeddruk','gewicht'],
    'Allergieën':['allergie','intolerant'],
  };
  const secties = {};
  let huidig = 'Dossier';
  let buf = '';
  tekst.split('\n').forEach(lijn => {
    const lijnLow = lijn.toLowerCase();
    let gevonden = false;
    for (const [s, kws] of Object.entries(sectieMap)) {
      if (kws.some(kw => lijnLow.includes(kw)) && lijn.length < 60) {
        if (buf.trim()) secties[huidig] = (secties[huidig]||'') + buf;
        huidig = s; buf = ''; gevonden = true; break;
      }
    }
    if (!gevonden) buf += lijn + '\n';
  });
  if (buf.trim()) secties[huidig] = (secties[huidig]||'') + buf;
  return secties;
}

// ── PDF lezen (generiek) ─────────────────────────────────────
async function leesPDF(file) {
  if (typeof pdfjsLib === 'undefined') throw new Error('PDF.js niet geladen. Voer download-pdfjs.bat uit.');
  const ab = await file.arrayBuffer();
  const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
  let tekst = '';
  for (let i = 1; i <= pdf.numPages; i++) {
    const pg = await pdf.getPage(i);
    const ct = await pg.getTextContent();
    tekst += '\n--- Pagina ' + i + ' ---\n' + ct.items.map(it=>it.str).join(' ');
  }
  return tekst;
}

